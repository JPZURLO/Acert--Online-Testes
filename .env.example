APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=5500
APP_TRUSTED_HOSTS=localhost,127.0.0.1
FLASK_DEBUG=false
COOKIE_SECURE=false
MAX_CONTENT_LENGTH=5242880
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false

DB_HOST=localhost
DB_PORT=3306
DB_USER=acert_app
DB_PASSWORD=troque-por-uma-senha-forte
DB_NAME=acert
# Em produção remota, informe o certificado CA do provedor para validar TLS.
DB_SSL_CA=

JWT_SECRET=gere-uma-chave-aleatoria-longa-e-exclusiva
