# Copie os valores para Environment Variables no Setup Python App.
APP_ENV=production
FLASK_DEBUG=false
COOKIE_SECURE=true
APP_TRUSTED_HOSTS=onlineteste.com.br,www.onlineteste.com.br
MAX_CONTENT_LENGTH=5242880
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false
PARTICIPANT_SESSION_HOURS=12

DB_HOST=localhost
DB_PORT=3306
DB_USER=USUARIO_CPANEL_BANCO
DB_PASSWORD=SENHA_FORTE_EXCLUSIVA
DB_NAME=NOME_CPANEL_BANCO
DB_SSL_CA=

JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_LONGA

PUBLIC_BASE_URL=https://www.onlineteste.com.br
SMTP_HOST=mail.onlineteste.com.br
SMTP_PORT=587
SMTP_USER=comercial@onlineteste.com.br
SMTP_PASSWORD=SENHA_ATUALIZADA_DO_EMAIL
SMTP_FROM=Online Teste <comercial@onlineteste.com.br>
SMTP_REPLY_TO=comercial@onlineteste.com.br
SMTP_STARTTLS=true
SMTP_SSL=false

# Em Passenger, use o Cron do cPanel em vez de thread permanente.
RECORDING_MAINTENANCE_ENABLED=false
RECORDING_MAINTENANCE_INTERVAL_SECONDS=900
PRIVATE_RECORDING_DIR=/home/USUARIO_CPANEL/online_test_private/recordings
PRIVATE_UPLOAD_DIR=/home/USUARIO_CPANEL/online_test_private/uploads